# Local server environment variables — copy to server/.env and fill in your values.

# ── LM Studio (local AI model) ──────────────────────────────────────────────
# LM Studio server URL (no trailing slash).
# IMPORTANT: must include the protocol (http:// or https://).
# Set this to the actual IP/hostname shown in LM Studio → Developer → Local Server.
# Example: LM_STUDIO_URL=http://192.168.1.100:1234
LM_STUDIO_URL=http://localhost:1234
# Model identifier as shown in LM Studio's "Loaded Models" panel.
# Use a vision-capable model (e.g. gemma-3-27b) for best results.
LM_STUDIO_MODEL=google/gemma-3-27b
# API key — LM Studio does not require authentication; any non-empty value works.
LM_STUDIO_API_KEY=lm-studio
# Enable vision (screenshots) for the AI agent. The model must support image inputs.
# Set to "false" to use text-only DOM analysis (saves bandwidth, works with text-only models).
LM_STUDIO_VISION=true
